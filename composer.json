{
	"name": "x3p0-dev/x3p0-framework",
	"license": "GPL-2.0-or-later",
	"scripts": {
		"build": [
			"composer update --no-dev",
			"composer dump-autoload -a --no-dev"
		],
		"dev": [
			"composer update",
			"composer dump-autoload"
		],
		"lint:php": "./vendor/bin/phpcs -d error_reporting=E_ALL^E_DEPRECATED -s --colors .",
		"fix:php": "./vendor/bin/phpcbf -d error_reporting=E_ALL^E_DEPRECATED -s --colors .",
		"test": "./vendor/bin/phpunit",
		"analyze": "./vendor/bin/phpstan analyse",
		"check": [
			"@lint:php",
			"@analyze",
			"@test"
		]
	},
	"autoload": {
		"psr-4": {
			"X3P0\\Framework\\": "src/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"X3P0\\Framework\\Tests\\": "tests/"
		}
	},
	"require": {
                "php": ">=8.1"
	},
	"require-dev": {
		"phpstan/phpstan": "^2.0",
		"phpunit/phpunit": "^10.5",
		"wp-coding-standards/wpcs": "^3.0",
		"phpcompatibility/phpcompatibility-wp": "*",
		"dealerdirect/phpcodesniffer-composer-installer": "^1.0"
	},
	"minimum-stability": "stable",
	"prefer-stable": true,
	"config": {
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true
		}
	},
	"authors": [
		{
			"name": "Justin Tadlock",
			"email": "justintadlock@gmail.com"
		}
	]
}
